[Unit]
Description=Run the Universal Agent hourly intel-digest delivery at the top of every hour (00..23) America/Chicago; runtime-gated to the active window unless UA_INTEL_DIGEST_DORMANCY is flipped (deploy-independent)

[Timer]
# OnCalendar wall-clock anchor — NEVER monotonic. Fires minute 0 of every hour
# (00..23) America/Chicago, DST handled by systemd; Persistent replays a missed
# slot inside a deploy window. systemd-255 honors the OnCalendar timezone suffix
# and the H..H hour range expands to one fire per hour (verified with
# `systemd-analyze calendar`).
#
# 24/7 SCHEDULE, RUNTIME-GATED: the schedule is full-day so the per-run dormancy
# decision lives in the ExecStart script (hourly_intel_digest_cron.py), which
# calls dormancy.should_run(env_var="UA_INTEL_DIGEST_DORMANCY"). Default stays
# windowed (work no-ops outside 6 AM–10 PM Houston); set that env var to a falsy
# value in Infisical to run 24/7 — no timer edit / reinstall needed to flip.
OnCalendar=*-*-* 00..23:00:00 America/Chicago
Persistent=true
RandomizedDelaySec=120
AccuracySec=1min
Unit=universal-agent-hourly-intel-digest.service

[Install]
WantedBy=timers.target
