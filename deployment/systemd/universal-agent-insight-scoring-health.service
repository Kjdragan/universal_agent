[Unit]
Description=Universal Agent insight-scoring calibration health email (S5 Phase A batch 1 — deploy-independent weekly timer)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ua
Group=ua
WorkingDirectory=/opt/universal_agent
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/opt/universal_agent/src
Environment=PYDANTIC_DISABLE_PLUGINS=logfire-plugin
# Secrets-bootstrap backstop (mirrors universal-agent-proactive-health) — LOAD
# BEARING for this job. insight_scoring_health is the ONLY batch-1 job that
# touches Infisical-resolved secrets: an LLM verdict call (services.llm_classifier
# ._call_llm), AgentMailService, and the activity DB path. Its main() calls
# initialize_runtime_secrets() with no profile arg, so it honors
# UA_DEPLOYMENT_PROFILE below. The deploy-bootstrapped .env (loaded last, and per
# systemd semantics it OVERRIDES these) carries the real values + Infisical
# machine-id creds; these inline vars are the .env-absent backstop that forces
# the strict `vps` Infisical production load rather than a keyless
# local_workstation run.
Environment=UA_DEPLOYMENT_PROFILE=vps
Environment=UA_INFISICAL_ENABLED=1
Environment=INFISICAL_ENVIRONMENT=production
EnvironmentFile=-/opt/universal_agent/.env
# Reads 7d of proactive_brief_scoring_log, asks one LLM for a calibration
# verdict, emails the operator. All failures are caught and logged (exits 0);
# exit 1 only on a true unhandled crash. 2G cap for the LLM client.
ExecStart=/opt/universal_agent/.venv/bin/python -m universal_agent.scripts.insight_scoring_health
MemoryMax=2G

[Install]
WantedBy=multi-user.target
