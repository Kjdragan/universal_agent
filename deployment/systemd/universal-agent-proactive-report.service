[Unit]
Description=Universal Agent proactive intelligence report (S5 Phase A batch 2 — shared oneshot, fired by the morning/midday/afternoon timers)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ua
Group=ua
WorkingDirectory=/opt/universal_agent
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/opt/universal_agent/src
Environment=PYDANTIC_DISABLE_PLUGINS=logfire-plugin
# Secrets-bootstrap backstop (mirrors universal-agent-proactive-health) — LOAD
# BEARING. proactive_report_agent makes an LLM call + an AgentMail send + reads
# the activity DB. Its main() now calls initialize_runtime_secrets() with NO
# profile arg, so it honors UA_DEPLOYMENT_PROFILE below. The deploy-bootstrapped
# .env (loaded last, and per systemd semantics it OVERRIDES these) carries the
# real values + Infisical machine-id creds; these inline vars are the .env-absent
# backstop forcing the strict `vps` production load rather than a keyless
# local_workstation run.
Environment=UA_DEPLOYMENT_PROFILE=vps
Environment=UA_INFISICAL_ENABLED=1
Environment=INFISICAL_ENVIRONMENT=production
EnvironmentFile=-/opt/universal_agent/.env
# ONE shared service for all three report slots — proactive_report_agent takes
# no slot arg; it derives morning/midday/afternoon framing from wall-clock time,
# so the same ExecStart run at the right time produces the right report. The
# three timer units (…-morning/-midday/-afternoon) all point Unit= here.
# Returns a dict (exit 0) even on a delivery failure — never marks .service
# failed by a finding. 2G cap for the LLM client.
ExecStart=/opt/universal_agent/.venv/bin/python -m universal_agent.scripts.proactive_report_agent
MemoryMax=2G
# LLM + AgentMail WebSocket can hang unboundedly; a hung oneshot stays active and
# blocks ALL its timers from firing. Bound to the job's old in-process budget
# (timeout_seconds=600) so a hang self-heals on the next slot.
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
