[Unit]
Description=Universal Agent morning briefing (S5 Phase A batch A4 — deploy-independent daily timer, SECRET-BEARING: UA_OPS_TOKEN + LLM)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ua
Group=ua
WorkingDirectory=/opt/universal_agent
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/opt/universal_agent/src
Environment=PYDANTIC_DISABLE_PLUGINS=logfire-plugin
# Secrets-bootstrap backstop (mirrors universal-agent-proactive-artifact-digest)
# — LOAD BEARING. briefings_agent fetches gateway telemetry with a Bearer
# UA_OPS_TOKEN, then dispatches an LLM briefing mission. main() was fixed (M2)
# from initialize_runtime_secrets(profile="local_workstation") to a bare call so
# it honors UA_DEPLOYMENT_PROFILE below; the inline vars are the .env-absent
# backstop forcing the strict `vps` production load (else UA_OPS_TOKEN is unset
# and main() sys.exit(1) before any briefing). .env OVERRIDES these when present.
# Same module as the evening briefing — modes differ by the --mode CLI arg, so
# evening gets its OWN unit (universal-agent-evening-briefing.service).
Environment=UA_DEPLOYMENT_PROFILE=vps
Environment=UA_INFISICAL_ENABLED=1
Environment=INFISICAL_ENVIRONMENT=production
EnvironmentFile=-/opt/universal_agent/.env
ExecStart=/opt/universal_agent/.venv/bin/python -m universal_agent.scripts.briefings_agent
MemoryMax=1G
# Telemetry fetch + LLM briefing dispatch. Bounded to its in-process budget
# (timeout_seconds=900) so a hung run self-heals on the next morning's slot.
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
