[Unit]
Description=Universal Agent evening briefing (S5 Phase A batch A4 — deploy-independent daily timer, SECRET-BEARING: UA_OPS_TOKEN + LLM)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ua
Group=ua
WorkingDirectory=/opt/universal_agent
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/opt/universal_agent/src
Environment=PYDANTIC_DISABLE_PLUGINS=logfire-plugin
# Secrets-bootstrap backstop (mirrors universal-agent-proactive-artifact-digest)
# — LOAD BEARING. SAME module as the morning briefing (briefings_agent), but a
# SEPARATE unit because the modes differ by CLI arg: ExecStart passes
# --mode=evening (briefings_agent._detect_mode reads it from sys.argv), so the
# two cannot share one service cleanly. main() was fixed (M2) to a bare
# initialize_runtime_secrets() so it honors UA_DEPLOYMENT_PROFILE below; the
# inline vars are the .env-absent backstop forcing the strict `vps` production
# load (else UA_OPS_TOKEN is unset and main() sys.exit(1)). .env OVERRIDES these
# when present.
Environment=UA_DEPLOYMENT_PROFILE=vps
Environment=UA_INFISICAL_ENABLED=1
Environment=INFISICAL_ENVIRONMENT=production
EnvironmentFile=-/opt/universal_agent/.env
ExecStart=/opt/universal_agent/.venv/bin/python -m universal_agent.scripts.briefings_agent --mode=evening
MemoryMax=1G
# Telemetry fetch + hourly-insight recap + LLM honorable-mention selection.
# Bounded to its in-process budget (timeout_seconds=900) so a hung run
# self-heals on the next evening's slot.
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
