[Unit]
Description=Run the Universal Agent Cody proactive-cleanup enqueue daily at 01:30 America/Chicago (deploy-independent)

[Timer]
# OnCalendar wall-clock anchor — NEVER monotonic. cron `30 1 * * *`
# America/Chicago (preserves the existing 01:30 schedule), DST handled by
# systemd; Persistent replays a missed slot inside a deploy window.
OnCalendar=*-*-* 01:30:00 America/Chicago
Persistent=true
RandomizedDelaySec=120
AccuracySec=1min
Unit=universal-agent-codie-proactive-cleanup.service

[Install]
WantedBy=timers.target
