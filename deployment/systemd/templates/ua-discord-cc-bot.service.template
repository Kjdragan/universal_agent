[Unit]
Description=Universal Agent - Command and Control Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__APP_USER__
Group=__APP_USER__
WorkingDirectory=__APP_ROOT__
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=__APP_ROOT__/src:__APP_ROOT__
Environment=PYDANTIC_DISABLE_PLUGINS=logfire-plugin
EnvironmentFile=-__APP_ROOT__/.env
ExecStart=/usr/local/bin/uv run --with "discord.py>=2.3.0" python -m discord_intelligence.cc_bot
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
