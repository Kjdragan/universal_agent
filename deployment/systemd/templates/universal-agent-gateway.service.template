[Unit]
Description=__UNIT_DESCRIPTION__
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__APP_USER__
Group=__APP_USER__
WorkingDirectory=__APP_ROOT__
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=__APP_ROOT__/src
Environment=PYDANTIC_DISABLE_PLUGINS=logfire-plugin
EnvironmentFile=-__APP_ROOT__/.env
ExecStart=__APP_ROOT__/.venv/bin/python -m universal_agent.gateway_server
Restart=always
RestartSec=5
# Resource limits — prevent process explosion from consuming all VPS memory.
# MemoryMax: hard cgroup limit (systemd kills cgroup if exceeded).
# MemoryHigh: soft limit (triggers kernel memory reclaim/swap pressure).
# TasksMax: caps total process count within the cgroup.
MemoryMax=8G
MemoryHigh=6G
TasksMax=500

[Install]
WantedBy=multi-user.target
