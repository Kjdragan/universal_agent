[Unit]
Description=Universal Agent CSI demo-triage LLM ranking (S5 Phase A batch A4 — deploy-independent twice-daily timer, SECRET-BEARING: Anthropic key)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ua
Group=ua
WorkingDirectory=/opt/universal_agent
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/opt/universal_agent/src
Environment=PYDANTIC_DISABLE_PLUGINS=logfire-plugin
# Secrets-bootstrap backstop (mirrors universal-agent-proactive-artifact-digest)
# — LOAD BEARING. csi_demo_triage_rank re-ranks pending candidates via one
# direct LLM call (ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN). main() calls
# initialize_runtime_secrets(profile=args.profile or None) — with no --profile
# the default is empty -> None, i.e. a bare call that honors UA_DEPLOYMENT_PROFILE
# below; the inline vars are the .env-absent backstop forcing the strict `vps`
# production load (else the Anthropic key is absent and ranking fails closed).
# .env OVERRIDES these when present.
Environment=UA_DEPLOYMENT_PROFILE=vps
Environment=UA_INFISICAL_ENABLED=1
Environment=INFISICAL_ENVIRONMENT=production
EnvironmentFile=-/opt/universal_agent/.env
ExecStart=/opt/universal_agent/.venv/bin/python -m universal_agent.scripts.csi_demo_triage_rank
MemoryMax=1G
# Pure SQL + one direct Anthropic LLM ranking call. Bounded to its in-process
# budget (timeout_seconds=600) so a hung call self-heals on the next slot.
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
