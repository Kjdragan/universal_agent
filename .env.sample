# Universal Agent environment template
# Copy to .env and fill in real values.

# ============================
# Core API Keys
# ============================
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=

# Anthropic / Z.ai
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ZAI_API_KEY=

# Optional integrations
GITHUB_PERSONAL_ACCESS_TOKEN=
EXA_API_KEY=
CONTEXT7_API_KEY=
CRAWL4AI_API_KEY=
LETTA_API_KEY=
LETTA_PROJECT_ID=
TODOIST_API_TOKEN=

# ============================
# Model Configuration
# ============================
MODEL_NAME=claude-sonnet-4-5-20250929
# Claude Code alias used by UA runtime (sonnet|opus|haiku). Leave blank to use MODEL_NAME/default.
UA_CLAUDE_CODE_MODEL=
# Enable Agent Teams features for team-based skills (e.g. ideation).
# UA override takes precedence, then native CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS.
UA_AGENT_TEAMS_ENABLED=1
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
MAX_TOKENS=15000
API_TIMEOUT_MS=30000
# Process turn runtime cap in seconds (0 = disabled/no hard cap)
UA_PROCESS_TURN_TIMEOUT_SECONDS=0

# ============================
# Logging / Observability
# ============================
LOG_LEVEL=INFO
ENVIRONMENT=development
CLAUDE_CODE_ENABLE_TELEMETRY=1
LOGFIRE_ORG=
LOGFIRE_PROJECT=
LOGFIRE_READ_TOKEN=
LOGFIRE_WRITE_TOKEN=
LOGFIRE_TOKEN=${LOGFIRE_WRITE_TOKEN}
# Logfire full payload instrumentation (debug mode)
UA_LOGFIRE_REDACTION_LEVEL=balanced
UA_LOGFIRE_FULL_PAYLOAD_MODE=false
UA_LOGFIRE_FULL_PAYLOAD_REDACT=true
UA_LOGFIRE_FULL_PAYLOAD_REDACT_EMAILS=true
UA_LOGFIRE_FULL_PAYLOAD_MAX_CHARS=50000


# ============================
# Telegram (optional)
# ============================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
WEBHOOK_SECRET=
WEBHOOK_URL=
# Long-running Telegram task timeout (seconds)
UA_TELEGRAM_TASK_TIMEOUT_SECONDS=1800
# Process-level Telegram bot liveness heartbeat for the VPS watchdog
UA_TELEGRAM_PROCESS_HEARTBEAT_FILE=/var/lib/universal-agent/heartbeat/telegram.heartbeat
UA_TELEGRAM_PROCESS_HEARTBEAT_INTERVAL_SECONDS=10
# Auto-render markdown attachments to HTML when uploading for Gmail sends.
# Set to 0 to keep raw .md attachments.
UA_GMAIL_RENDER_MARKDOWN_ATTACHMENTS=1

# ============================
# Memory (canonical OpenClaw-style memory)
# ============================
# Recommended defaults: ON.
UA_MEMORY_ENABLED=1
UA_MEMORY_PROVIDER=auto
UA_MEMORY_SOURCES=memory,sessions
UA_MEMORY_SCOPE=direct_only
UA_MEMORY_SESSION_ENABLED=1
UA_MEMORY_FLUSH_ENABLED=1
UA_MEMORY_FLUSH_SOFT_THRESHOLD_TOKENS=4000
# Session transition memory capture mode:
# - transcript   : include transcript/run-log excerpts (legacy)
# - summary_only : capture only structured summaries (recommended for low-noise dev)
UA_MEMORY_ROLLOVER_MODE=transcript
# Shared canonical memory workspace so memory survives session workspace cleanup.
# Use an absolute path in production (example: /opt/universal_agent/Memory_System/ua_shared_workspace).
UA_SHARED_MEMORY_DIR=Memory_System/ua_shared_workspace
UA_MEMORY_MAX_TOKENS=800
UA_MEMORY_RECENT_ENTRIES=8
UA_MEMORY_FLUSH_MAX_CHARS=4000

# ============================
# Heartbeat (gateway scheduler)
# ============================
# Default off. Enable explicitly for dev/testing.
UA_ENABLE_HEARTBEAT=0
UA_DISABLE_HEARTBEAT=0
UA_HEARTBEAT_INTERVAL=300
UA_HEARTBEAT_EVERY=30m
UA_HEARTBEAT_ACTIVE_HOURS=
UA_HEARTBEAT_ACTIVE_START=
UA_HEARTBEAT_ACTIVE_END=
UA_HEARTBEAT_TIMEZONE=USER
UA_HEARTBEAT_REQUIRE_FILE=0
UA_HEARTBEAT_PROMPT=
UA_HEARTBEAT_ACK_MAX_CHARS=300
UA_HEARTBEAT_OK_TOKENS=HEARTBEAT_OK,UA_HEARTBEAT_OK
UA_HEARTBEAT_EXEC_TIMEOUT=300
UA_HEARTBEAT_IDLE_TIMEOUT=300
# Keep idle sessions registered by default so proactive heartbeat behavior is not silently suppressed.
# Set to 1 only if you explicitly want idle sessions removed from the heartbeat scheduler.
UA_HEARTBEAT_UNREGISTER_IDLE=0
UA_HB_DELIVERY_MODE=last
UA_HB_EXPLICIT_SESSION_IDS=
UA_HB_SHOW_OK=false
UA_HB_SHOW_ALERTS=true
UA_HB_DEDUPE_WINDOW=86400
UA_HB_USE_INDICATOR=false
UA_HEARTBEAT_MOCK_RESPONSE=0

# ============================
# Process Heartbeat (OS-level liveness — NOT the Heartbeat Service above)
# ============================
# A lightweight daemon THREAD writes a Unix timestamp to a file every N seconds.
# The VPS service watchdog reads this file to detect if the gateway process is
# alive, WITHOUT depending on the async event loop (which may be blocked by
# long-running LLM calls).
#
# ⚠️  DO NOT CONFUSE with the "Heartbeat (gateway scheduler)" section above.
#     That is the APPLICATION-LEVEL agent scheduler (runs every ~30 min, drives
#     HEARTBEAT.md, Todoist, proactive tasks, etc.).
#     This section is the PROCESS-LEVEL liveness signal (10-second file writes).
#
# See: src/universal_agent/process_heartbeat.py
# See: scripts/vps_service_watchdog.sh
UA_PROCESS_HEARTBEAT_FILE=/var/lib/universal-agent/heartbeat/gateway.heartbeat
UA_PROCESS_HEARTBEAT_INTERVAL_SECONDS=10
# Watchdog staleness threshold (seconds). If the heartbeat file is older than
# this, the watchdog considers the process dead.
# UA_WATCHDOG_HEARTBEAT_STALE_SECONDS=300

# ============================
# Cron (proactive jobs)
# ============================
UA_ENABLE_CRON=0
UA_DISABLE_CRON=0
UA_CRON_MAX_CONCURRENCY=1
UA_CRON_MOCK_RESPONSE=0
UA_SYSTEM_EVENTS_MAX=100
UA_GATEWAY_PROCESS_STDIO_REDIRECT=0

# ============================
# Ops / Control Plane
# ============================
# Optional bearer token to protect /api/v1/ops/* endpoints
UA_OPS_TOKEN=
NEXT_PUBLIC_UA_OPS_TOKEN=
# JWT signing secret for /auth/ops-token issuance
UA_OPS_JWT_SECRET=
# Transition switch for legacy static ops token fallback
UA_OPS_AUTH_ALLOW_LEGACY=true
# Redis message bus password (corporation/infrastructure/redis)
REDIS_PASSWORD=
# Delegation stream bus toggles/config
UA_DELEGATION_REDIS_ENABLED=1
# Optional full URL override (takes precedence over host/port/db)
UA_REDIS_URL=
UA_REDIS_HOST=127.0.0.1
UA_REDIS_PORT=6379
UA_REDIS_DB=0
UA_DELEGATION_STREAM_NAME=ua:missions:delegation
UA_DELEGATION_CONSUMER_GROUP=ua_workers
UA_DELEGATION_DLQ_STREAM=ua:missions:dlq
UA_DELEGATION_CONSUMER_NAME=
UA_FACTORY_ID=
UA_FACTORY_REGISTRATION_INTERVAL_SECONDS=60
UA_TUTORIAL_BOOTSTRAP_TRANSPORT=auto
# Optional path for ops config (defaults to AGENT_RUN_WORKSPACES/ops_config.json)
UA_OPS_CONFIG_PATH=
# Optional path for approvals store (defaults to AGENT_RUN_WORKSPACES/approvals.json)
UA_APPROVALS_PATH=
# Optional runtime DB overrides:
# - UA_RUNTIME_DB_PATH controls Simone queue/checkpoint operational state.
# - UA_CODER_VP_DB_PATH controls CODIE mission/session telemetry state.
# Keeping these separate reduces sqlite write-lock contention under mixed loads.
# UA_RUNTIME_DB_PATH=<repo>/AGENT_RUN_WORKSPACES/runtime_state.db
# UA_CODER_VP_DB_PATH=<repo>/AGENT_RUN_WORKSPACES/coder_vp_state.db
# External primary VP runtime (control-plane/data-plane split)
UA_VP_DISPATCH_MODE=db_pull
UA_VP_ENABLED_IDS=vp.coder.primary,vp.general.primary
UA_VP_EXTERNAL_DISPATCH_ENABLED=0
UA_VP_HARD_BLOCK_UA_REPO=1
UA_VP_CODER_WORKSPACE_ROOT=
UA_VP_GENERAL_WORKSPACE_ROOT=
UA_VP_POLL_INTERVAL_SECONDS=5
UA_VP_LEASE_TTL_SECONDS=120
UA_VP_MAX_CONCURRENT_MISSIONS=1
# Allowlisted handoff root for CODIE artifacts/outputs that need to be re-imported.
UA_VP_HANDOFF_ROOT=/opt/universal_agent/vp_handoff
# Gateway/API transport and websocket timeout policy
UA_GATEWAY_HTTP_TIMEOUT_SECONDS=60
UA_API_GATEWAY_OWNER_TIMEOUT_SECONDS=20
UA_GATEWAY_WS_HANDSHAKE_TIMEOUT_SECONDS=20
UA_GATEWAY_WS_OPEN_TIMEOUT_SECONDS=20
UA_GATEWAY_WS_CLOSE_TIMEOUT_SECONDS=10
UA_GATEWAY_WS_PING_INTERVAL_SECONDS=20
UA_GATEWAY_WS_PING_TIMEOUT_SECONDS=20
UA_WS_SEND_TIMEOUT_SECONDS=8
UA_SESSION_CANCEL_WAIT_SECONDS=10
# Dashboard activity feed / notifications (staging rollout defaults)
UA_DASHBOARD_EVENTS_SSE_ENABLED=1
UA_ACTIVITY_DIGEST_ENABLED=1
UA_ACTIVITY_STREAM_RETENTION_DAYS=14
UA_ACTIVITY_DIGEST_MAX_SAMPLE_IDS=20
UA_ACTIVITY_DIGEST_EXCLUDE_KINDS=
# Deployment profile defaults (local_workstation | standalone_node | vps)
UA_DEPLOYMENT_PROFILE=local_workstation
# Factory role routing (HEADQUARTERS | LOCAL_WORKER | STANDALONE_NODE)
FACTORY_ROLE=HEADQUARTERS
# Capability toggle for VP coder lane
ENABLE_VP_CODER=true
# Optional provider override (ZAI | ANTHROPIC | OPENAI | OLLAMA)
LLM_PROVIDER_OVERRIDE=
# =============================================================================
# INFISICAL — Single source of truth for ALL secrets (local + VPS)
# =============================================================================
# Both local_workstation and VPS use the SAME Infisical Machine Identity and
# project. There is no separate local setup — just copy the three credential
# values (CLIENT_ID, CLIENT_SECRET, PROJECT_ID) from the VPS .env.
#
# How to get the values from the VPS (one-time copy):
#   ssh root@<vps-ip> 'grep -E "^INFISICAL_CLIENT_(ID|SECRET)=|^INFISICAL_PROJECT_ID=" /opt/universal_agent/.env'
#   Then paste the output into the corresponding fields below.
#
# Runtime behaviour:
#   - infisical_loader uses overwrite=True so Infisical secrets WIN over any
#     raw values sourced from .env via the start scripts.
#   - VPS: UA_INFISICAL_STRICT is unset → auto-strict (fail-closed).
#   - Local: UA_INFISICAL_STRICT=0 + ALLOW_DOTENV_FALLBACK=1 → graceful
#     fallback to .env if Infisical is unreachable (safe during dev).
#
# Adding new secrets: add to Infisical project ONLY — do not put raw values
# in .env. Both machines will pick them up on next restart automatically.
UA_INFISICAL_ENABLED=1
# 0 for local_workstation (graceful fallback), leave blank for VPS (auto strict)
UA_INFISICAL_STRICT=0
UA_INFISICAL_ALLOW_DOTENV_FALLBACK=1
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
INFISICAL_SECRET_PATH=/
# =============================================================================
# NotebookLM (Infisical-backed, VPS-first)
# =============================================================================
# Non-secret runtime toggles. Secrets (such as NOTEBOOKLM_AUTH_COOKIE_HEADER)
# must live in Infisical and are injected at runtime.
UA_ENABLE_NOTEBOOKLM_MCP=0
UA_NOTEBOOKLM_AUTH_SEED_ENABLED=1
UA_NOTEBOOKLM_PROFILE=vps
UA_NOTEBOOKLM_CLI_COMMAND=nlm
UA_NOTEBOOKLM_MCP_COMMAND=notebooklm-mcp
# Optional local fallback .env path override
UA_DOTENV_PATH=
# Restrict workspace selection to UA_WORKSPACES_DIR when disabled
UA_ALLOW_EXTERNAL_WORKSPACES=0
# Override skills directory (defaults to .claude/skills)
UA_SKILLS_DIR=
# Comma-separated list of disabled skills (additional to ops config)
UA_SKILLS_DISABLED=
# Optional web UI URL used for channel probes
UA_WEB_UI_URL=
# Optional local mirror roots for VPS debug sync
# Recommended persistent defaults (avoid tmp for long-lived mirrors):
# UA_LOCAL_MIRROR_DIR=<repo>/AGENT_RUN_WORKSPACES/remote_vps_workspaces
# UA_LOCAL_ARTIFACTS_MIRROR_DIR=<repo>/artifacts/remote_vps_artifacts
# UA_REMOTE_SYNC_STATE_DIR=<repo>/AGENT_RUN_WORKSPACES/remote_vps_sync_state
# Completion-aware mirror policy across session activities (web UI/API, hooks, Telegram).
# Keep enabled to avoid pulling half-written session/artifact output.
# UA_REMOTE_SYNC_REQUIRE_READY_MARKER=true
# UA_REMOTE_SYNC_READY_MARKER_FILENAME=sync_ready.json
# UA_REMOTE_SYNC_READY_MIN_AGE_SECONDS=45
# UA_REMOTE_SYNC_READY_SESSION_PREFIX=session_,tg_
# Runtime marker writer used by gateway run_query (e.g., Telegram sessions).
# UA_RUNTIME_SYNC_READY_MARKER_ENABLED=true
# UA_RUNTIME_SYNC_READY_MARKER_FILENAME=sync_ready.json
# Optional API-side aliases used by /api/vps/* endpoints:
# UA_VPS_WORKSPACES_MIRROR_DIR=<repo>/AGENT_RUN_WORKSPACES/remote_vps_workspaces
# UA_VPS_ARTIFACTS_MIRROR_DIR=<repo>/artifacts/remote_vps_artifacts

# ============================
# YouTube Tutorial Playlist Watcher (native UA poller)
# ============================
# Playlist to watch for new tutorial videos (replaces CSI Ingester youtube_playlist source)
YT_TUTORIALS_PLAYLIST_ID=
# YouTube Data API v3 key (required for playlist polling)
YOUTUBE_API_KEY=
# Threads API credentials (CSI Threads adapters)
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
THREADS_TOKEN_EXPIRES_AT=
# Threads webhook/publishing scaffolding (phase 1 defaults are disabled)
CSI_THREADS_WEBHOOK_ENABLED=0
THREADS_WEBHOOK_VERIFY_TOKEN=
CSI_THREADS_PUBLISHING_ENABLED=0
THREADS_OAUTH_REDIRECT_URI=
# How often to poll the playlist (seconds, default 60, minimum 15)
YT_TUTORIALS_POLL_INTERVAL_SECONDS=60
# Set to 0 to disable the watcher without removing the env var
UA_YT_PLAYLIST_WATCHER_ENABLED=1
# Telegram chat ID for tutorial pipeline stage notifications (optional)
# Stages: new_video_detected, tutorial_started, tutorial_ready, tutorial_failed, queue_overflow
YOUTUBE_TUTORIAL_TELEGRAM_CHAT_ID=
# Sequential concurrency (1 = one tutorial run at a time, recommended)
UA_HOOKS_AGENT_DISPATCH_CONCURRENCY=1
# Per-run timeout for YouTube tutorial agent runs (seconds, default 1800 = 30 min)
UA_HOOKS_YOUTUBE_TIMEOUT_SECONDS=1800
# Idle sub-turn timeout for YouTube tutorial runs (seconds)
UA_HOOKS_YOUTUBE_IDLE_TIMEOUT_SECONDS=900

# ============================
# Hooks / YouTube Ingest (optional)
# ============================
# Enable hooks ingress and set a bearer token for /api/v1/hooks/*
UA_HOOKS_ENABLED=0
UA_HOOKS_TOKEN=

# Local YouTube transcript ingest worker mode:
# - "" (default): disabled
# - local_worker: call /api/v1/youtube/ingest before dispatching YouTube runs
UA_HOOKS_YOUTUBE_INGEST_MODE=
UA_HOOKS_YOUTUBE_INGEST_URL=
UA_HOOKS_YOUTUBE_INGEST_TOKEN=
UA_HOOKS_YOUTUBE_INGEST_TIMEOUT_SECONDS=120
UA_HOOKS_YOUTUBE_INGEST_RETRY_ATTEMPTS=3
UA_HOOKS_YOUTUBE_INGEST_RETRY_DELAY_SECONDS=20
UA_HOOKS_YOUTUBE_INGEST_RETRY_MAX_DELAY_SECONDS=90
UA_HOOKS_YOUTUBE_INGEST_RETRY_JITTER_SECONDS=3
UA_HOOKS_YOUTUBE_INGEST_MIN_CHARS=160
UA_HOOKS_YOUTUBE_INGEST_COOLDOWN_SECONDS=600
UA_HOOKS_YOUTUBE_INGEST_INFLIGHT_TTL_SECONDS=900
# If 1, proceed with degraded run when ingest fails; if 0, defer dispatch until ingest recovers.
UA_HOOKS_YOUTUBE_INGEST_FAIL_OPEN=0

# ============================
# CSI Signals Ingest (optional)
# ============================
# Enable dedicated CSI -> UA ingest endpoint at /api/v1/signals/ingest
UA_SIGNALS_INGEST_ENABLED=0
# Shared secret used for both bearer auth and HMAC verification for CSI requests
UA_SIGNALS_INGEST_SHARED_SECRET=
# Optional comma-separated allowlist of CSI instance IDs (empty means no instance filtering)
UA_SIGNALS_INGEST_ALLOWED_INSTANCES=
# Allowed drift for X-CSI-Timestamp (seconds)
UA_SIGNALS_INGEST_TIMESTAMP_TOLERANCE_SECONDS=300

# CSI delivery health/source-map thresholds (shared by gateway + canary + SLO gatekeeper)
UA_CSI_DELIVERY_SOURCE_MIN_EVENTS=youtube_channel_rss=1,reddit_discovery=1,threads_owned=0,threads_trends_seeded=0,threads_trends_broad=0,csi_analytics=0
UA_CSI_DELIVERY_MIN_THREADS_OWNED_EVENTS_24H=0
UA_CSI_DELIVERY_MIN_THREADS_SEEDED_EVENTS_24H=0
UA_CSI_DELIVERY_MIN_THREADS_BROAD_EVENTS_24H=0
UA_CSI_SLO_WATCHED_SOURCES=

# ============================
# AgentMail (Simone's native inbox)
# ============================
# Master toggle — set to 1 to enable AgentMail integration
UA_AGENTMAIL_ENABLED=1
# API key from https://app.agentmail.to — add to Infisical first
AGENTMAIL_API_KEY=
# Inbox address (Simone D <oddcity216@agentmail.to>)
UA_AGENTMAIL_INBOX_ADDRESS=oddcity216@agentmail.to
# Username used when creating a new inbox (default: simone)
UA_AGENTMAIL_INBOX_USERNAME=simone
# 1 = send emails directly; 0 = create drafts for human approval (default)
UA_AGENTMAIL_AUTO_SEND=0
# WebSocket real-time listener for inbound emails
UA_AGENTMAIL_WS_ENABLED=1
# WS reconnect backoff (seconds)
UA_AGENTMAIL_WS_RECONNECT_BASE_DELAY=2
UA_AGENTMAIL_WS_RECONNECT_MAX_DELAY=120

# ============================
# Misc
# ============================
DEFAULT_USER_ID=
EDGAR_IDENTITY=
UA_PRIMARY_EMAIL=
UA_NOTIFICATION_EMAIL=kevinjdragan@gmail.com
CONSOLE_WIDTH=0
# UV cache path (optional, keep inside repo to avoid permission errors)
UV_CACHE_DIR=
# Watchdog health probe timeout (seconds)
UA_WATCHDOG_HTTP_TIMEOUT_SECONDS=8

# Web UI websocket reconnect/keepalive tuning
NEXT_PUBLIC_UA_WS_MAX_RECONNECT_ATTEMPTS=20
NEXT_PUBLIC_UA_WS_RECONNECT_BASE_DELAY_MS=1000
NEXT_PUBLIC_UA_WS_RECONNECT_MAX_DELAY_MS=30000
NEXT_PUBLIC_UA_WS_CONNECT_TIMEOUT_MS=15000
NEXT_PUBLIC_UA_WS_PING_INTERVAL_MS=30000
NEXT_PUBLIC_UA_WS_STALE_AFTER_MS=90000

# ============================
# Token limits
# ============================
CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000
MAX_MCP_OUTPUT_TOKENS=64000
UA_BATCH_MAX_WORDS=50000

# ============================
# Google Workspace CLI (gws) — MCP-based Google API access
# ============================
# Master toggle — set to 1 to enable gws as primary Google Workspace path
UA_ENABLE_GWS_CLI=0
# Force-disable override (takes precedence over enable)
# UA_DISABLE_GWS_CLI=0
# Path to gws binary (default: looks on $PATH)
# UA_GWS_BINARY_PATH=gws
# Comma-separated services to expose (default: gmail,calendar,drive,sheets)
# UA_GWS_SERVICES=gmail,calendar,drive,sheets
# Expose helper tools like +triage, +send, +agenda (default: 1)
# UA_GWS_ENABLE_HELPERS=1
# Expose workflow tools like +standup-report (default: 1)
# UA_GWS_ENABLE_WORKFLOWS=1
# Tool granularity: full (1 tool/method) or compact (1 tool/service)
# UA_GWS_TOOL_MODE=full
# Auth credentials are managed in Infisical (do NOT set here in production):
#   GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE  — service account or authorized user JSON
#   GOOGLE_WORKSPACE_CLI_IMPERSONATED_USER — user email for domain-wide delegation
#   GOOGLE_WORKSPACE_CLI_TOKEN             — direct access token (CI use)

# ----------------------------
# gws Workspace Event Listener (Phase 5) — Gmail inbox polling
# ----------------------------
# Set to 1 to enable background Gmail polling and hooks dispatch (default: OFF)
UA_ENABLE_GOOGLE_WORKSPACE_EVENTS=0
# Force-disable override (takes precedence over enable)
# UA_DISABLE_GOOGLE_WORKSPACE_EVENTS=0
# Poll cadence in seconds (min 15, default 60)
# UA_GWS_EVENTS_POLL_INTERVAL_SECONDS=60
# Gmail label filter — comma-separated label IDs (default: INBOX,UNREAD)
# UA_GWS_EVENTS_GMAIL_LABELS=INBOX,UNREAD
# Max messages fetched per poll cycle (default: 20)
# UA_GWS_EVENTS_MAX_RESULTS=20
# Hook subpath new messages are dispatched to (default: gmail/new_message)
# UA_GWS_EVENTS_DISPATCH_HOOK=gmail/new_message

# ============================
# Z.AI Vision (optional)
# ============================
# Enables zai_vision MCP server for video/image analysis.
# Z_AI_API_KEY=
# Z_AI_MODE=ZAI

# ============================
# Artifacts (Durable Outputs)
# ============================
# Persistent artifacts root. Default: <repo-root>/artifacts
# Artifacts are NOT intended to be committed to git.
# UA_ARTIFACTS_DIR=/absolute/path/to/artifacts
