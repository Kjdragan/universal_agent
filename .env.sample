# Universal Agent bootstrap-only environment template
#
# This file is intentionally small.
# Stage-shared runtime config and secrets belong in Infisical, not in the
# local `.env` file. Local `.env` is for bootstrap + machine identity only.

# =============================================================================
# Infisical bootstrap
# =============================================================================
UA_INFISICAL_ENABLED=1
# Local development may allow dotenv fallback. VPS should normally leave this
# blank and rely on profile-driven strict mode.
UA_INFISICAL_STRICT=0
UA_INFISICAL_ALLOW_DOTENV_FALLBACK=1
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_API_URL=https://app.infisical.com
INFISICAL_ENVIRONMENT=development
INFISICAL_SECRET_PATH=/

# =============================================================================
# Machine-local runtime identity
# =============================================================================
UA_RUNTIME_STAGE=development
FACTORY_ROLE=HEADQUARTERS
UA_DEPLOYMENT_PROFILE=local_workstation
UA_MACHINE_SLUG=kevins-desktop

# Optional local fallback dotenv path override for workstation development.
UA_DOTENV_PATH=

# Notes:
# - Localhost HQ development:
#     INFISICAL_ENVIRONMENT=development
#     UA_RUNTIME_STAGE=development
#     FACTORY_ROLE=HEADQUARTERS
#     UA_DEPLOYMENT_PROFILE=local_workstation
#
# - Desktop worker attached to staging:
#     INFISICAL_ENVIRONMENT=staging
#     UA_RUNTIME_STAGE=staging
#     FACTORY_ROLE=LOCAL_WORKER
#     UA_DEPLOYMENT_PROFILE=local_workstation
#
# - VPS staging headquarters:
#     INFISICAL_ENVIRONMENT=staging
#     UA_RUNTIME_STAGE=staging
#     FACTORY_ROLE=HEADQUARTERS
#     UA_DEPLOYMENT_PROFILE=vps
#
# - VPS production headquarters:
#     INFISICAL_ENVIRONMENT=production
#     UA_RUNTIME_STAGE=production
#     FACTORY_ROLE=HEADQUARTERS
#     UA_DEPLOYMENT_PROFILE=vps
