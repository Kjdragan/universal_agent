[Unit]
Description=Run CSI source quality assessment daily (evening)
PartOf=csi.target

[Service]
Type=oneshot
# Run as ua (the owner of the canonical DB below). MUST match the DB owner:
# a root writer on the ua-owned WAL DB would create root-owned -wal/-shm files
# and break the live ua ingester's access.
User=ua
WorkingDirectory=/opt/universal_agent/CSI_Ingester/development
ExecStart=/opt/universal_agent/CSI_Ingester/development/.venv/bin/python scripts/csi_source_quality_assessment.py --lookback-days 7
# Canonical production DB (was the stale dev DB .../development/var/csi.db,
# which has 0 rows — the assessment silently scored 0/0 every night).
Environment=CSI_DB_PATH=/var/lib/universal-agent/csi/csi.db
TimeoutStartSec=300
