server {
  server_name app.clearspringcg.com;

  # ──────────────────────────────────────────────────────────────────
  # All traffic goes through Next.js (port 3000).
  # Next.js rewrites in next.config.js proxy /api/* → gateway (8002)
  # and /ws/* → gateway (8002) for WebSocket.
  # ──────────────────────────────────────────────────────────────────

  # Briefs — served DIRECTLY by the gateway backend (port 8002), not Next.js.
  # The gateway (gateway_server.py::briefs_viewer_get) renders a self-contained
  # HTML page for each proactive_artifacts row; this is what the "Read full
  # brief →" links in the hourly intel digest point at.
  # WITHOUT this block, /briefs/* falls through to `location /` (Next.js :3000),
  # which has no such route and returns "404: This page could not be found" —
  # silently breaking every brief link in every intel digest email.
  location ^~ /briefs/ {
    proxy_pass http://127.0.0.1:8002;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # UA websocket for chat stream — needs explicit upgrade headers.
  # Routed through Next.js which already rewrites ws/* → gateway.
  location ^~ /ws/ {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
  }

  # Everything (pages, API, etc.) → Next.js
  location / {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/app.clearspringcg.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/app.clearspringcg.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = app.clearspringcg.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


  listen 80;
  server_name app.clearspringcg.com;
    return 404; # managed by Certbot


}
