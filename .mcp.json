{
  "mcpServers": {
    "agentation": {
      "command": "npx",
      "args": [
        "-y",
        "agentation-mcp",
        "server"
      ]
    },
    "AgentMail": {
      "command": "npx",
      "args": [
        "-y",
        "agentmail-mcp"
      ],
      "env": {
        "AGENTMAIL_API_KEY": "${AGENTMAIL_API_KEY}"
      }
    },
    "arxiv-mcp-server": {
      "command": "uvx",
      "args": [
        "arxiv-mcp-server"
      ]
    },
    "discord": {
      "command": "uvx",
      "args": [
        "mcp-discord"
      ],
      "env": {
        "DISCORD_TOKEN": "${DISCORD_BOT_TOKEN}"
      }
    }
  }
}