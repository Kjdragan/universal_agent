{
  "mcpServers": {
    "agentation": {
      "command": "npx",
      "args": [
        "-y",
        "agentation-mcp",
        "server"
      ]
    },
    "todoist-ai": {
      "command": "npx",
      "args": [
        "-y",
        "@doist/todoist-ai"
      ],
      "env": {
        "TODOIST_API_KEY": "${TODOIST_API_KEY}"
      }
    },
    "AgentMail": {
      "command": "npx",
      "args": [
        "-y",
        "agentmail-mcp"
      ],
      "env": {
        "AGENTMAIL_API_KEY": "${AGENTMAIL_API_KEY}"
      }
    }
  }
}