# Multimodal RAG Environment Configuration
# Copy this file to .env and fill in your API keys

# Required: Google API key for Gemini Embedding 2
GOOGLE_API_KEY=your_google_api_key_here

# Required: OpenAI API key for GPT-5.4
OPENAI_API_KEY=your_openai_api_key_here

# Optional: ChromaDB configuration
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=pdf_pages

# Optional: Batch size for embedding ingestion
BATCH_SIZE=10

# Optional: Number of results to retrieve
TOP_K=5

# Optional: Image cache directory
IMAGE_CACHE_DIR=./image_cache
