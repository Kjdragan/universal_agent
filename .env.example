
# ── TGTG Sniper ───────────────────────────────────────────────────────────────
# Runtime secrets bootstrap (Infisical Machine Identity)
UA_DEPLOYMENT_PROFILE=local_workstation
FACTORY_ROLE=HEADQUARTERS
ENABLE_VP_CODER=true
LLM_PROVIDER_OVERRIDE=
UA_INFISICAL_ENABLED=1
# Strict defaults are inferred by profile:
# - vps / standalone_node => strict fail-closed
# - local_workstation => non-strict with optional dotenv fallback
UA_INFISICAL_STRICT=
UA_INFISICAL_ALLOW_DOTENV_FALLBACK=1
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
INFISICAL_SECRET_PATH=/
# NotebookLM runtime toggles (secrets are injected via Infisical)
UA_ENABLE_NOTEBOOKLM_MCP=0
UA_NOTEBOOKLM_AUTH_SEED_ENABLED=1
UA_NOTEBOOKLM_PROFILE=vps
UA_NOTEBOOKLM_CLI_COMMAND=nlm
UA_NOTEBOOKLM_MCP_COMMAND=notebooklm-mcp
UA_OPS_TOKEN=
UA_OPS_JWT_SECRET=
UA_OPS_AUTH_ALLOW_LEGACY=true
REDIS_PASSWORD=
UA_DELEGATION_REDIS_ENABLED=1
UA_REDIS_URL=
UA_REDIS_HOST=127.0.0.1
UA_REDIS_PORT=6379
UA_REDIS_DB=0
UA_DELEGATION_STREAM_NAME=ua:missions:delegation
UA_DELEGATION_CONSUMER_GROUP=ua_workers
UA_DELEGATION_DLQ_STREAM=ua:missions:dlq
UA_DELEGATION_CONSUMER_NAME=
UA_FACTORY_ID=
UA_FACTORY_REGISTRATION_INTERVAL_SECONDS=60
UA_TUTORIAL_BOOTSTRAP_TRANSPORT=auto

# Optional local dotenv fallback override path (local_workstation only)
UA_DOTENV_PATH=

TGTG_EMAIL=your@email.com

# After running `login`, these are auto-populated:
TGTG_ACCESS_TOKEN=
TGTG_REFRESH_TOKEN=
TGTG_COOKIE=

# Store area coordinates (send these regardless of your proxy location)
TGTG_LATITUDE=51.5074
TGTG_LONGITUDE=-0.1278
TGTG_RADIUS=5

# Specific item IDs to watch (comma-separated). Leave blank = all favourites.
TGTG_WATCHED_ITEMS=

# Set true to auto-reserve bags when detected
TGTG_AUTO_PURCHASE=false
TGTG_ORDER_COUNT=1

# Polling intervals (seconds)
TGTG_POLL_IDLE=300
TGTG_POLL_ACTIVE=30
TGTG_POLL_SNIPING=15
TGTG_POLL_WINDOW_MINUTES=90

# Rotating residential proxies (comma-separated HTTP/SOCKS5 URLs)
# e.g. http://user:pass@gate.smartproxy.com:7000,http://user:pass@gate.smartproxy.com:7001
TGTG_PROXIES=

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard (default binds to localhost; set 0.0.0.0 for network access)
TGTG_DASHBOARD_HOST=127.0.0.1
TGTG_DASHBOARD_PORT=8765

# Payment reminder — minutes before pickup closes to send a "pay now!" Telegram message.
# Set to 0 to disable.
TGTG_PAYMENT_REMINDER_MINUTES=15

# Auto-scan — re-scan the region catalog every N hours while the monitor is running.
# Set to 0 to disable. New stores trigger a Telegram alert + webhook.
TGTG_SCAN_INTERVAL_HOURS=24

# Daily spend cap — stop auto-buying once this many currency units have been spent today.
# Leave blank to disable.
TGTG_DAILY_BUDGET=

# Webhook — HTTP POST endpoint for stock/order/dead-item events (JSON body).
# Disabled by default; set to your endpoint URL to enable (opt-in).
TGTG_WEBHOOK_URL=

# Dev-mode stub data for Mission Control dashboard (default: true in dev)
# Set to "false" to disable stub fallbacks and see real 502 errors
UA_DEV_MODE_STUBS=true

# ── Link payments (Stripe Link CLI) ───────────────────────────────────────────
# Production secrets/config live in Infisical, NOT in this file. This block
# documents the variable names so operators know what to provision in Infisical.
# The auth blob is generated locally via scripts/bootstrap_link_auth.sh, then
# pasted into Infisical as LINK_AUTH_BLOB (never committed).
#
# Master switch (default OFF). Live spend requires BOTH UA_ENABLE_LINK_LIVE=1
# AND UA_LINK_TEST_MODE=0 — either missing → test mode.
UA_ENABLE_LINK=0
UA_ENABLE_LINK_LIVE=0
UA_LINK_TEST_MODE=1
# Default Link payment method id (csmrpd_...). Discover via `link-cli payment-methods list`.
UA_LINK_DEFAULT_PAYMENT_METHOD_ID=
# Local auth-blob seed restored on VPS startup (Infisical-injected; do not commit).
UA_LINK_AUTH_SEED_ENABLED=1
LINK_AUTH_BLOB=
# Force stub mode even with master switch on (ops escape hatch + test fixture).
# Set to 1 to neuter all real Link CLI calls without flipping UA_ENABLE_LINK off.
UA_LINK_FORCE_STUB=0
# Override link-cli binary path (defaults to globally-installed link-cli, then npx).
UA_LINK_CLI_PATH=
# Per-call ceiling and 24h rolling daily cap (cents).
UA_LINK_MAX_AMOUNT_CENTS=5000
UA_LINK_DAILY_BUDGET_CENTS=10000
# Optional comma-separated hostname allowlist. Empty = no merchant filter.
UA_LINK_MERCHANT_ALLOWLIST=
# Per-channel entry-point toggles (master switch must also be on).
UA_LINK_ENTRY_CHAT=1
UA_LINK_ENTRY_UI=1
UA_LINK_ENTRY_SKILL=1
# Browser-automated checkout via agent_purchaser sub-agent (Phase 2.5+).
UA_LINK_AUTO_CHECKOUT=1
# Daily cap on captcha-solver invocations from purchase flows (protects shared NopeCHA quota).
UA_LINK_DAILY_CAPTCHA_BUDGET=20
# Signed-URL card-details page TTL.
UA_LINK_SIGNED_URL_TTL_SECONDS=900
# Audit log retention (days) and reconciler poll interval (seconds).
UA_LINK_AUDIT_RETENTION_DAYS=90
UA_LINK_RECONCILER_INTERVAL_SECONDS=30
