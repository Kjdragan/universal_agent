TL_JS = """<script>
(function(){
var tlw=document.getElementById('tlw'),tgl=document.getElementById('tgl'),
    q=document.getElementById('q'),cnt=document.getElementById('cnt'),
    total=document.querySelectorAll('.p').length,active=new Set();
function open(on){tlw.classList.toggle('hide',!on);
  tgl.textContent=on?'\\u25b4 collapse the timeline':'\\u25be expand the timeline';
  if(on)tlw.scrollLeft=tlw.scrollWidth;}
tgl.addEventListener('click',function(){open(tlw.classList.contains('hide'));});
function match(p){
  var t=q.value.trim().toLowerCase();
  if(t){var ws=t.split(/\\s+/),s=p.getAttribute('data-s');
    for(var i=0;i<ws.length;i++)if(s.indexOf(ws[i])<0)return false;}
  if(!active.size)return true;
  if(p.hasAttribute('data-o'))return active.has('~other');
  return active.has(p.getAttribute('data-r'));}
function filter(){
  var fa=!!(q.value.trim()||active.size),vis=0,SHOW=10;
  document.querySelectorAll('.day:not(.empty)').forEach(function(d){
    var exp=d.classList.contains('exp'),mshown=0;
    d.querySelectorAll('.p').forEach(function(p){
      var m=match(p),show=false;
      if(m){show=fa||exp||mshown<SHOW;mshown++;vis++;}
      p.style.display=show?'':'none';});
    var mb=d.querySelector('.mr');
    if(mb){
      if(fa){mb.style.display='none';}
      else if(exp){mb.style.display='';mb.textContent='\\u25b4 fewer';}
      else if(mshown>SHOW){mb.style.display='';mb.textContent='+ '+(mshown-SHOW)+' more \\u25be';}
      else{mb.style.display='none';}}
    d.classList.toggle('dim',!mshown);});
  cnt.textContent=vis+' of '+total;
  if(fa&&tlw.classList.contains('hide'))open(true);}
q.addEventListener('input',filter);
filter();
document.addEventListener('click',function(ev){
  var el=ev.target.closest('.lg');
  if(el){var r=el.getAttribute('data-r');
    if(active.has(r))active.delete(r);else active.add(r);
    el.classList.toggle('on');filter();return;}
  el=ev.target.closest('.cp');
  if(el){var c=el.parentNode.querySelector('code');
    navigator.clipboard.writeText(c.textContent).then(function(){
      el.textContent='\\u2713';setTimeout(function(){el.textContent='copy';},1200);});
    return;}
  el=ev.target.closest('.mr');
  if(el){el.closest('.day').classList.toggle('exp');filter();return;}
  el=ev.target.closest('.ob');
  if(el){open(true);
    var d=document.querySelector('.day[data-d="'+el.getAttribute('data-d')+'"]');
    if(d&&!d.classList.contains('empty')){
      d.scrollIntoView({behavior:'smooth',inline:'center',block:'nearest'});
      d.classList.add('hit');setTimeout(function(){d.classList.remove('hit');},1600);}
    return;}
  el=ev.target.closest('.ph');
  if(el){var p=el.parentNode,was=p.classList.contains('open');
    document.querySelectorAll('.p.open').forEach(function(x){x.classList.remove('open');});
    if(!was)p.classList.add('open');}
});
})();
</script>"""


def render_timeline(rows, days):
    """Second living page: a sideways-scrolling day-by-day timeline. Condensed
    by default (overview strip only); the full lane expands on demand, and
    every marker explodes into a detail card with a copyable resume command."""
    e = html.escape
    now = time.time()
    # deep search index: unique words from the transcript tail of the newest
    # sessions, so search matches what a session DID, not just how it started
    from collections import Counter
    for r in rows[:TL_DEEP]:
        texts, late_name = tail_records(r["path"])
        if late_name and not r["name"]:
            r["name"] = late_name
        words = re.findall(r"[a-z0-9][a-z0-9_.-]{2,24}", " ".join(texts).lower())
        # frequency-ranked so truncation drops rare noise, not whole alphabet ranges
        r["deep"] = " ".join(w for w, _ in Counter(words).most_common(300))[:2500]

    counts = {}
    for r in rows:
        counts[r["repo"]] = counts.get(r["repo"], 0) + 1
    ranked = sorted(counts, key=lambda k: (-counts[k], k))
    color = {repo: TL_COLORS[i] for i, repo in enumerate(ranked[:len(TL_COLORS)])}

    lt = time.localtime(now)
    day0 = time.mktime((lt.tm_year, lt.tm_mon, lt.tm_mday, 0, 0, 0, 0, 0, -1))
    keys = [time.strftime("%Y-%m-%d", time.localtime(day0 - d * 86400))
            for d in range(days - 1, -1, -1)]
    buckets = {k: [] for k in keys}
    for r in rows:
        k = time.strftime("%Y-%m-%d", time.localtime(r["mtime"]))
        if k in buckets:
            buckets[k].append(r)
    for k in keys:
        buckets[k].sort(key=lambda r: r["mtime"])
    peak = max([len(v) for v in buckets.values()] + [1])

    ov = []
    for i, k in enumerate(keys):
        n = len(buckets[k])
        h = max(6, round(64 * n / peak)) if n else 2
        z = "" if n else " z"
        plural = "s" if n != 1 else ""
        lbl = "<b>%s</b>" % k[5:] if i % 7 == 0 else ""
        ov.append('<div class="ob%s" data-d="%s" title="%s · %d session%s">'
                  '<i style="height:%dpx"></i>%s</div>' % (z, k, k, n, plural, h, lbl))

    lg = []
    for i, repo in enumerate(ranked[:len(TL_COLORS)]):
        lg.append('<button class="lg" data-r="%s"><i style="background:%s"></i>%s'
                  '<span>%d</span></button>' % (e(repo), TL_COLORS[i], e(repo), counts[repo]))
    rest = sum(counts[r] for r in ranked[len(TL_COLORS):])
    if rest:
        lg.append('<button class="lg" data-r="~other"><i style="background:%s"></i>'
                  'other<span>%d</span></button>' % (TL_OTHER, rest))

    cols = []
    for k in keys:
        rs = buckets[k]
        wd = time.strftime("%a", time.strptime(k, "%Y-%m-%d"))
        wk = " wk" if wd in ("Sat", "Sun") else ""
        if not rs:
            cols.append('<div class="day empty%s" data-d="%s" title="%s %s — quiet"></div>'
                        % (wk, k, wd, k))
            continue
        pills = []
        for r in rs:
            repo, name, first = r["repo"], r["name"] or "", r["first"]
            c = color.get(repo, TL_OTHER)
            other = "" if repo in color else ' data-o="1"'
            hh = time.strftime("%H:%M", time.localtime(r["mtime"]))
            head = name or (first or r["summary"] or "(empty session)")[:90]
            hl_cls = "hl" if name else "hl un"
            hay = e(" ".join([repo, name, first, r["summary"],
                              r.get("gist") or "", r.get("deep") or ""]).lower())
            gist = r.get("gist") or r["summary"]
            detail = []
            if gist:
                detail.append('<div class="g">%s</div>' % e(gist))
            if first and first != head:
                detail.append('<div class="fp">“%s”</div>' % e(first))
            cmd = "cd %s && %s --resume %s" % (r["cwd"], r["launcher"], r["sid"])
            detail.append('<div class="row"><code>%s</code>'
                          '<button class="cp">copy</button></div>' % e(cmd))
            pills.append(
                '<div class="p" data-r="%s"%s data-s="%s" style="border-left-color:%s">'
                '<div class="ph"><span class="tm">%s</span><span class="rp">%s</span>'
                '<span class="acct">%s</span><div class="%s">%s</div></div>'
                '<div class="pd">%s</div></div>'
                % (e(repo), other, hay, c, hh, e(repo), r["acct"], hl_cls,
                   e(head), "".join(detail)))
        more = ('<button class="mr">+ %d more ▾</button>' % (len(rs) - TL_DAY_SHOW)
                if len(rs) > TL_DAY_SHOW else "")
        cols.append('<div class="day%s" data-d="%s"><div class="dh">%s %s<span>%d</span></div>%s%s</div>'
                    % (wk, k, wd, k[5:], len(rs), "".join(pills), more))

    stamp = time.strftime("%Y-%m-%d %H:%M %Z")
    return ("""<!doctype html><html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Claude session timeline</title>""" + TL_CSS + """</head><body>
<header><div class="wrap"><h1>Claude session timeline</h1>
<div class="sub">%d sessions · last %d days · both accounts · one sideways-scrolling lane.
The strip below shows sessions per day — click a bar to jump to that day. Click any card
to expand its gist and resume command. Search covers titles, first prompts, gists — and for
recent sessions, words from the transcript tail (what the session actually became).
Busy days show 10 cards; "+ N more" reveals the rest.
List view: <a href="%s">session atlas</a>. Updated %s.</div></div></header>
<div class="wrap">
<div class="ctl"><input id="q" type="search" placeholder="search %d sessions…">
<span id="cnt">%d of %d</span>%s</div>
<div class="ov">%s</div>
<button id="tgl">▾ expand the timeline</button>
<div id="tlw" class="tlw hide"><div class="tl">%s</div></div>
</div>""" % (len(rows), days, ATLAS_URL, stamp, len(rows), len(rows), len(rows),
             "".join(lg), "".join(ov), "".join(cols))
            + TL_JS + "</body></html>")


def find(rows, query, limit=8):
    """Token-cheap lookup for in-session use: compact matches, resume-ready.
    A skill should call THIS, never Read the atlas HTML into context."""
    terms = [w for w in query.lower().split() if w]
    scored = []
    for r in rows:
        hay = " ".join([r["repo"], r["name"] or "", r["first"], r["summary"],
                        r.get("gist") or ""]).lower()
        score = sum(hay.count(w) for w in terms)
        if score:
            scored.append((score, r))
    scored.sort(key=lambda s: (-s[0], -s[1]["mtime"]))
    if not scored:
        print(f"no sessions match: {query}")
        return
    for score, r in scored[:limit]:
        when = time.strftime("%m-%d %H:%M", time.localtime(r["mtime"]))
        topic = (r["name"] or r["summary"] or r["first"])[:110]
        print(f"{when}  [{r['repo']}]  {topic}")
        print(f"        cd {r['cwd']} && {r['launcher']} --resume {r['sid']}")


def main():
    a = sys.argv[1:]
    days = int(a[a.index("--days") + 1]) if "--days" in a else 45
    cap = int(a[a.index("--max") + 1]) if "--max" in a else 140
    if "--find" in a:
        rows = collect(max(days, 90), 400)
        return find(rows, a[a.index("--find") + 1]) or 0
    # one scan feeds both pages: the timeline carries EVERY session in the
    # window, the atlas stays the curated newest-N list with fresh LLM gists
    tl_rows = collect(days, TL_MAX)
    rows = tl_rows[:cap]
    add_gists(rows)
    open(OUT, "w").write(render(rows, days))
    attach_cached_gists(tl_rows)
    open(OUT2, "w").write(render_timeline(tl_rows, days))
    print(f"atlas: {len(rows)} sessions → {OUT} + timeline: {len(tl_rows)} → {OUT2}")
    if "--publish" in a:
        env = dict(os.environ, UA_SCRATCH_ARCHIVE_ENABLED="0")  # living pages — no per-day archive churn
        rc = 0
        for path, slug in ((OUT, "session-atlas"), (OUT2, "session-timeline")):
            r = subprocess.run([PUBLISH, path, slug], env=env,
                               capture_output=True, text=True)
            print(r.stdout.strip() or r.stderr.strip()[-300:])
            rc = rc or r.returncode
        return rc
    return 0


if __name__ == "__main__":
    sys.exit(main())
