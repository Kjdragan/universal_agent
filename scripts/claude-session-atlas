.fp{font-size:12px;color:#5c5a55;font-style:italic;margin-bottom:6px}
.lb{display:inline-block;color:#a05a00;font-style:normal;font-weight:650;font-size:10px;
text-transform:uppercase;letter-spacing:.5px;margin-right:5px}
.mt{font-family:monospace;font-size:10.5px;color:#a09d96;margin-bottom:6px}
.row{display:flex;gap:6px;align-items:flex-start}
.row code{word-break:break-all;flex:1}
.cp{border:1px solid #d8d5cf;background:#fff;border-radius:6px;font-size:11px;padding:2px 8px;cursor:pointer}
.mr{display:block;width:100%;border:1px dashed #d8d5cf;background:#fff;border-radius:8px;
padding:5px;font:12px Inter,sans-serif;color:#5c5a55;cursor:pointer;margin:0 0 8px}
.mr:hover{border-color:#a09d96}
.day.slim{width:178px}
.slim .p{padding:6px 8px}
.slim .hl{font-size:12px;-webkit-line-clamp:1}
.slim .p.open .hl{-webkit-line-clamp:unset}
.slim .dh{font-size:11px;color:#898781}
</style>"""

def _pill(r, color, tfmt, live={}):
    """One session card."""
    e = html.escape
    repo, name, first = r["repo"], r["name"] or "", r["first"]
    c = color.get(repo, TL_OTHER)
    other = "" if repo in color else ' data-o="1"'
    hh = time.strftime(tfmt, time.localtime(r["mtime"]))
    head = name or (first or r["summary"] or "(empty session)")[:90]
    hl_cls = "hl" if name else "hl un"
    hay = e(" ".join([repo, name, first, r["summary"],
                      r.get("gist") or "", r.get("deep") or ""]).lower())
    gist = r.get("gist") or r["summary"]
    detail = []
    fmt = "%a %m-%d %H:%M"
    last = time.strftime(fmt, time.localtime(r["mtime"]))
    if r.get("start"):
        meta = "started %s · last active %s" % (
            time.strftime(fmt, time.localtime(r["start"])), last)
    else:
        meta = "last active %s" % last
    detail.append('<div class="mt">%s</div>' % meta)
    if gist:
        detail.append('<div class="g"><b class="lb">left off</b>%s</div>' % e(gist))
    if first and first != head:
        detail.append('<div class="fp"><b class="lb">asked</b>“%s”</div>' % e(first))
    cmd = "cd %s && %s --resume %s" % (r["cwd"], r["launcher"], r["sid"])
    detail.append('<div class="row"><code>%s</code>'
                  '<button class="cp">copy</button></div>' % e(cmd))
    run = r["sid"] in live
    badge = '<span class="live">● running</span>' if run else ""
    return ('<div class="p" data-r="%s"%s data-s="%s" data-sid="%s"%s style="border-left-color:%s">'
            '<button class="op" title="open this session in a desktop terminal">▶ open</button>'
            '<div class="ph"><span class="tm">%s</span><span class="rp">%s</span>'
            '<span class="acct">%s</span>%s<div class="%s">%s</div></div>'
            '<div class="pd">%s</div></div>'
            % (e(repo), other, hay, r["sid"], ' data-live="1"' if run else "", c,
               hh, e(repo), r["acct"], badge, hl_cls, e(head), "".join(detail)))


def _col(color, cls, dd, extra, label, rs, show_n, tfmt, live={}):
    """One filterable group (a day, or a week bucket) of session cards."""
    pills = "".join(_pill(r, color, tfmt, live) for r in rs)
    more = ('<button class="mr">+ %d more ▾</button>' % (len(rs) - show_n)
            if len(rs) > show_n else "")
    return ('<div class="day%s" data-d="%s"%s data-n="%d">'
            '<div class="dh">%s<span>%d</span></div><div class="gr">%s</div>%s</div>'
            % (cls, dd, extra, show_n, label, len(rs), pills, more))


def _project_colors(rows):
    counts = {}
    for r in rows:
        counts[r["repo"]] = counts.get(r["repo"], 0) + 1
    ranked = sorted(counts, key=lambda k: (-counts[k], k))
    color = {repo: TL_COLORS[i] for i, repo in enumerate(ranked[:len(TL_COLORS)])}
    return counts, ranked, color


def _legend(counts, ranked, color):
    e = html.escape
    lg = []
    for repo in ranked[:len(TL_COLORS)]:
        lg.append('<button class="lg" data-r="%s"><i style="background:%s"></i>%s'
                  '<span>%d</span></button>' % (e(repo), color[repo], e(repo), counts[repo]))
    rest = sum(counts[r] for r in ranked[len(TL_COLORS):])
    if rest:
        lg.append('<button class="lg" data-r="~other"><i style="background:%s"></i>'
                  'other<span>%d</span></button>' % (TL_OTHER, rest))
    return "".join(lg)


def _day_buckets(rows, days):
    lt = time.localtime()
    day0 = time.mktime((lt.tm_year, lt.tm_mon, lt.tm_mday, 0, 0, 0, 0, 0, -1))
    keys = [time.strftime("%Y-%m-%d", time.localtime(day0 - d * 86400))
            for d in range(days - 1, -1, -1)]
    buckets = {k: [] for k in keys}
    for r in rows:
        k = time.strftime("%Y-%m-%d", time.localtime(r["mtime"]))
        if k in buckets:
            buckets[k].append(r)
    for k in keys:
        buckets[k].sort(key=lambda r: r["mtime"])
    return keys, buckets


def _overview(keys, buckets):
    peak = max([len(v) for v in buckets.values()] + [1])
    ov = []
    for i, k in enumerate(keys):
        n = len(buckets[k])
        h = max(6, round(64 * n / peak)) if n else 2
        z = "" if n else " z"
        plural = "s" if n != 1 else ""
        lbl = "<b>%s</b>" % k[5:] if i % 7 == 0 else ""
        ov.append('<div class="ob%s" data-d="%s" title="%s · %d session%s">'
                  '<i style="height:%dpx"></i>%s</div>' % (z, k, k, n, plural, h, lbl))
    return "".join(ov)


