#!/usr/bin/env python3
"""claude-session-atlas — the standing map of what's building across ALL Claude
Code sessions (both accounts): per-project groups, session names, topic
snippets, and ready-to-paste resume commands, published as ONE living
scratchpad page (stable URL) the operator can open whenever he's lost.

Companion to `claude-sessions` (the terminal lister). Mostly deterministic;
every session younger than GIST_DAYS additionally carries a GLM-written "where
we left off" gist derived from the TAIL of the transcript (bounded read — an 800k-token
session costs the same as a short one), cached per (session, mtime) in
~/.cache/claude-session-atlas/summaries.json so regenerations only pay for
sessions that actually changed. Runs on the ZAI flat plan (glm-5-turbo via
ZAI_API_KEY/ANTHROPIC_AUTH_TOKEN from the login shell); with no key in the
environment the LLM step is skipped and the page degrades to the old behavior.

  claude-session-atlas                  # write HTML to stdout-path + print URL hint
  claude-session-atlas --publish        # publish all slugs (atlas + ladder + redirect stub)
  claude-session-atlas --days 30 --max 150

Every run renders TWO living pages from the same scan: the per-project atlas
(slug session-atlas) and the vertical recency ladder (slug session-ladder) —
every session in the window, newest first, density falling with age, with
click-to-expand cards (initial query + GLM "left off" tail gist + resume
command) and live deep search. The retired session-timeline slug redirects
to the ladder. The newest GIST_MAX sessions younger than GIST_DAYS carry a
tail gist, cached per (sid, mtime), at most GIST_BUDGET new calls per run.

Scheduled: desktop user timer claude-session-atlas.timer (daily 07:30 CT,
Persistent=true — catches up after sleep). Install:
  cp ~/lrepos/universal_agent/deployment/desktop-systemd-user/claude-session-atlas.* \
     ~/.config/systemd/user/ && systemctl --user daemon-reload && \
  systemctl --user enable --now claude-session-atlas.timer
"""
import calendar, glob, html, json, os, re, subprocess, sys, time

HOMES = [("a1", "claudereal", os.path.expanduser("~/.claude/projects")),
         ("a2", "claude2",    os.path.expanduser("~/.claude-acct2/projects"))]
PUBLISH = os.path.expanduser("~/lrepos/universal_agent/scripts/publish_scratch.sh")
OUT = "/tmp/claude-session-atlas.html"
OUT2 = "/tmp/claude-session-timeline.html"
OUT3 = "/tmp/claude-session-ladder.html"
ATLAS_URL = "https://uaonvps.taildcc090.ts.net/scratch/session-atlas/claude-session-atlas.html"
LADDER_URL = "https://uaonvps.taildcc090.ts.net/scratch/session-ladder/claude-session-ladder.html"
# the ladder's ↻ button GETs this — a socket-activated handler on the desktop
# (claude-session-atlas-refresh.socket) behind `tailscale serve --https=8747`
REFRESH_URL = "https://mint-desktop.taildcc090.ts.net:8747/"
REDIRECT = ('<!doctype html><html lang="en"><head><meta charset="utf-8">'
            '<meta http-equiv="refresh" content="0;url=%s"><title>moved</title>'
            '</head><body><p>This design was retired — continue to the '
            '<a href="%s">Claude session ladder</a>.</p></body></html>'
            % (LADDER_URL, LADDER_URL))
# dataviz reference categorical palette (light mode, validated order — top 8
# projects by session count keep a fixed hue, everything else folds to neutral)
TL_COLORS = ["#2a78d6", "#1baf7a", "#eda100", "#008300",
             "#4a3aa7", "#e34948", "#e87ba4", "#eb6834"]
TL_OTHER = "#898781"
TL_MAX = 2000       # ladder carries every session in the window (atlas stays curated)
TL_DEEP = 400       # newest N sessions also get transcript-TAIL words in the search index
                    # (titles alone miss what a session became — e.g. a session titled by
                    # its first prompt that spent the day building something else entirely)
CACHE = os.path.expanduser("~/.cache/claude-session-atlas/summaries.json")
LIVE_DIRS = [os.path.expanduser("~/.claude/sessions"),        # per-pid live registry,
             os.path.expanduser("~/.claude-acct2/sessions")]  # both accounts
BOILER = "This session is being continued from a previous conversation"
GIST_DAYS = 30     # gist eligibility: younger than this AND within GIST_MAX newest
GIST_MAX = 450     # operator call: no need to gist further back than the newest 450
GIST_BUDGET = 150  # max NEW gist LLM calls per run — the timer converges over days
GIST_PROMPT = (
    "Below is the tail end of a Claude Code working session transcript. In 1-2 "
    "sentences (max 45 words), state where the work currently stands and what is "
    "immediately pending — the gist the operator needs to remember where he left "
    "off. Present tense, specific names/artifacts/decisions, no preamble, no markdown."
)


def _text(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        return " ".join(b.get("text", "") for b in content if isinstance(b, dict))
    return ""


def scan(path, max_lines=4000):
    """Cheap single pass: cwd, session name, first real user msg, last
    summary, and the session's start timestamp (first record's ISO ts)."""
    cwd = name = first_user = last_summary = started = None
    try:
        with open(path, errors="replace") as fh:
            for i, ln in enumerate(fh):
                if i > max_lines and cwd and (first_user or name):
                    break
                try:
                    rec = json.loads(ln)
                except Exception:
                    continue
                if started is None and rec.get("timestamp"):
                    started = rec["timestamp"]
                if cwd is None and rec.get("cwd"):
                    cwd = rec["cwd"]
                if rec.get("type") == "summary" and rec.get("summary"):
                    last_summary = rec["summary"]
                # the harness writes structured rename records — canonical,
                # last-write-wins (late renames are also caught by tail_records)
                if rec.get("type") == "custom-title" and rec.get("customTitle"):
                    name = rec["customTitle"]
                elif rec.get("type") == "agent-name" and rec.get("agentName"):
                    name = rec["agentName"]
                m = rec.get("message") or {}
                if rec.get("type") == "user" and first_user is None:
                    t = _text(m.get("content")).strip()
                    if (t and not t.startswith("<") and "Caveat:" not in t[:40]
                            and not t.startswith(BOILER)):
                        first_user = t
                if name is None and "named this session" in ln:
                    s = _text(m.get("content"))
                    j = s.find("named this session")
                    if j >= 0:
                        name = s[j + 18:].split(".")[0].strip().strip(' "“”')
    except Exception:
        pass
    return cwd, name, first_user, last_summary, started


def tail_records(path, tail_bytes=262144, keep=24):
    """Bounded read of a transcript's TAIL: the last meaningful user/assistant
    texts (oldest→newest) + any late rename. Never reads the whole file."""
    texts, late_name = [], None
    try:
        size = os.path.getsize(path)
        with open(path, "rb") as fh:
            if size > tail_bytes:
                fh.seek(size - tail_bytes)
                fh.readline()  # drop the partial line at the seek point
            data = fh.read().decode(errors="replace")
        for ln in data.splitlines():
            try:
                rec = json.loads(ln)
            except Exception:
                continue
            if rec.get("type") == "custom-title" and rec.get("customTitle"):
                late_name = rec["customTitle"]
            m = rec.get("message") or {}
            t = None
            if rec.get("type") == "user" and not rec.get("isMeta"):
                u = _text(m.get("content")).strip()
                if u and not u.startswith("<") and "Caveat:" not in u[:40] and not u.startswith(BOILER):
                    t = "OPERATOR: " + u
            elif rec.get("type") == "assistant":
                a = _text(m.get("content")).strip()
                if a:
                    t = "AGENT: " + a
            if t:
                texts.append(t[:1500])
    except Exception:
        pass
    return texts[-keep:], late_name


def _ensure_zai_key():
    """The gist step needs a ZAI key, but timers/services carry no secrets.
    Least-privilege bootstrap: universal-auth via the infisical CLI, fetch
    ONLY the one key, export it for _glm_gist. Silent no-op on any failure
    (the page degrades to cached gists — old behavior)."""
    if os.environ.get("ZAI_API_KEY") or os.environ.get("ANTHROPIC_AUTH_TOKEN"):
        return
    try:
        creds = {}
        for ln in open(os.path.expanduser("~/lrepos/universal_agent/.env")):
            k, _, v = ln.strip().partition("=")
            if k in ("INFISICAL_CLIENT_ID", "INFISICAL_CLIENT_SECRET"):
                creds[k] = v.strip().strip('"')
        if len(creds) < 2:
            return
        tok = subprocess.run(
            ["infisical", "login", "--method=universal-auth",
             "--client-id=" + creds["INFISICAL_CLIENT_ID"],
             "--client-secret=" + creds["INFISICAL_CLIENT_SECRET"],
             "--plain", "--silent"],
            capture_output=True, text=True, timeout=30).stdout.strip()
        if not tok:
            return
        for name in ("ZAI_API_KEY", "ANTHROPIC_AUTH_TOKEN"):
            r = subprocess.run(
                ["infisical", "secrets", "get", name,
                 "--projectId=9970e5b7-d48a-4ed8-a8af-43e923e67572",
                 "--env=development", "--plain", "--silent"],
                capture_output=True, text=True, timeout=30,
                env=dict(os.environ, INFISICAL_TOKEN=tok))
            if r.returncode == 0 and r.stdout.strip():
                os.environ[name] = r.stdout.strip()
                return
    except Exception:
        pass


def _glm_gist(tail_texts, timeout=45):
    """One bounded glm-5-turbo call (ZAI flat plan, stdlib urllib — no deps).
    Returns None on any failure or when no key is in the environment."""
    import urllib.request
    key = os.environ.get("ZAI_API_KEY") or os.environ.get("ANTHROPIC_AUTH_TOKEN")
    if not key or not tail_texts:
        return None
    prompt = GIST_PROMPT + "\n\n---\n" + "\n\n".join(tail_texts)[-9000:]
    req = urllib.request.Request(
        "https://api.z.ai/api/anthropic/v1/messages",
        data=json.dumps({"model": "glm-5-turbo", "max_tokens": 160,
                         "messages": [{"role": "user", "content": prompt}]}).encode(),
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json",
                 "anthropic-version": "2023-06-01"})
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            d = json.load(r)
        out = " ".join(b.get("text", "") for b in d.get("content", [])
                       if isinstance(b, dict)).strip()
        return out or None
    except Exception:
        return None


def add_gists(rows):
    """Give every session younger than GIST_DAYS a 'where we left off' gist
    from the transcript tail. Cached per (sid, mtime): the past never changes,
    so regenerations only pay LLM cost for sessions that changed since the
    last run — and at most GIST_BUDGET new calls per run (the daily timer
    converges over a few days; interactive runs stay bounded). Older rows
    still get their cached gist/name back."""
    try:
        cache = json.load(open(CACHE))
    except Exception:
        cache = {}
    cutoff = time.time() - GIST_DAYS * 86400
    has_key = bool(os.environ.get("ZAI_API_KEY") or os.environ.get("ANTHROPIC_AUTH_TOKEN"))
    budget = GIST_BUDGET if has_key else 0
    dirty = False
    for i, r in enumerate(rows):  # rows arrive newest-first
        c = cache.get(r["sid"])
        if c:
            r["gist"] = c.get("gist") or ""
            if not r["name"] and c.get("name"):
                r["name"] = c["name"]
        if (i >= GIST_MAX or r["mtime"] < cutoff
                or (c and c.get("mtime") == int(r["mtime"]) and c.get("gist"))):
            continue
        if budget <= 0:
            continue
        budget -= 1
        texts, late_name = tail_records(r["path"])
        if late_name:
            r["name"] = late_name
        g = _glm_gist(texts)
        if g:  # never cache a failed call — it would block the retry forever
            r["gist"] = g
            cache[r["sid"]] = {"mtime": int(r["mtime"]), "gist": g,
                               "name": r["name"] or ""}
            dirty = True
    if dirty:
        os.makedirs(os.path.dirname(CACHE), exist_ok=True)
        json.dump(cache, open(CACHE, "w"))


def build_deep_index(rows):
    """Deep search index: frequency-ranked words from the transcript TAIL of
    the newest TL_DEEP sessions, so search matches what a session actually
    became — not just how it started. Mutates rows (deep/name)."""
    from collections import Counter
    for r in rows[:TL_DEEP]:
        texts, late_name = tail_records(r["path"])
        if late_name and not r["name"]:
            r["name"] = late_name
        words = re.findall(r"[a-z0-9][a-z0-9_.-]{2,24}", " ".join(texts).lower())
        # frequency-ranked so truncation drops rare noise, not alphabet ranges
        r["deep"] = " ".join(w for w, _ in Counter(words).most_common(300))[:2500]


def live_status():
    """sessionId -> status for currently-running sessions (best-effort)."""
    out = {}
    for live_dir in LIVE_DIRS:
        try:
            for f in glob.glob(os.path.join(live_dir, "*.json")):
                try:
                    d = json.load(open(f))
                    if d.get("sessionId") and d.get("status") == "running":
                        out[d["sessionId"]] = "running"
                except Exception:
                    continue
        except Exception:
            pass
    return out


def collect(days, cap):
    cutoff = time.time() - days * 86400
    rows = []
    for label, launcher, root in HOMES:
        for f in glob.glob(os.path.join(root, "*", "*.jsonl")):
            if "/-tmp" in f or ".orphaned-" in f or "-claude-jobs-" in f:
                continue
            mt = os.path.getmtime(f)
            if mt >= cutoff and os.path.getsize(f) > 2000:
                rows.append((mt, label, launcher, f))
    rows.sort(reverse=True)
    out = []
    for mt, label, launcher, f in rows[:cap]:
        cwd, name, first, summ, started = scan(f)
        if not cwd:
            continue
        start = None
        if started:
            try:
                start = calendar.timegm(time.strptime(started[:19], "%Y-%m-%dT%H:%M:%S"))
            except Exception:
                start = None
        # worktree cwds (<repo>/.claude/worktrees/<x>) consolidate silently into
        # their parent repo — worktrees are plumbing the operator never sees
        repo = os.path.basename(cwd)
        if "/.claude/worktrees/" in cwd:
            repo = os.path.basename(cwd.partition("/.claude/worktrees/")[0])
        out.append(dict(mtime=mt, start=start, acct=label, launcher=launcher,
                        sid=os.path.basename(f)[:-6], path=f,
                        repo=repo, cwd=cwd, name=name, gist="",
                        first=(first or "")[:200], summary=(summ or "")[:280]))
    return out


def _ago(secs):
    if secs < 3600: return f"{max(1, int(secs // 60))}m ago"
    if secs < 172800: return f"{int(secs // 3600)}h ago"
    return f"{int(secs // 86400)}d ago"


def _heat(rs, days=14):
    """Pure-CSS per-repo activity strip: one cell per day (oldest→newest),
    intensity = sessions last-touched that day."""
    now = time.time()
    counts = [0] * days
    for r in rs:
        d = int((now - r["mtime"]) // 86400)
        if 0 <= d < days:
            counts[d] += 1
    cells = []
    for d in reversed(range(days)):
        c = counts[d]
        if c:
            cells.append(f'<i style="opacity:{min(1.0, 0.3 + 0.28 * c):.2f}"></i>')
        else:
            cells.append('<i class="z"></i>')
    return f'<span class="heat" title="last {days} days">{"".join(cells)}</span>'


def render(rows, days):
    groups = {}
    for r in rows:
        groups.setdefault(r["repo"], []).append(r)
    ordered = sorted(groups.items(), key=lambda kv: -kv[1][0]["mtime"])
    e = html.escape
    parts = [f"""<!doctype html><html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Claude session atlas</title><style>
body{{margin:0;background:#faf9f7;color:#1a1a1f;font:15px/1.55 Inter,-apple-system,sans-serif;padding:0 0 60px}}
.wrap{{max-width:960px;margin:0 auto;padding:0 20px}}
header{{border-bottom:3px solid #e04e00;background:#fff;padding:26px 0 18px;margin-bottom:26px}}
h1{{font-size:24px;margin:0 0 4px}} .sub{{color:#5c5a55;font-size:13px}}
h2{{font-size:17px;margin:26px 0 8px}} h2 .n{{color:#e04e00;font-family:monospace;font-size:13px}}
h2 .ago{{color:#a09d96;font-size:12px;font-weight:400;margin-left:8px}}
.heat{{margin-left:10px;vertical-align:middle}}
.heat i{{display:inline-block;width:7px;height:11px;margin-right:2px;background:#e04e00;border-radius:2px}}
.heat i.z{{background:#e6e3dd}}
.live{{display:inline-block;font-size:10.5px;font-weight:600;padding:0 6px;border-radius:9px;margin-left:6px;background:#e8f7ec;color:#0a7d33}}
.s{{background:#fff;border:1px solid #e6e3dd;border-radius:9px;padding:12px 15px;margin:8px 0}}
.when{{font-family:monospace;font-size:11.5px;color:#a05a00}}
.nm{{font-weight:650}} .unnamed{{color:#5c5a55;font-weight:400;font-style:italic}}
.topic{{font-size:13px;color:#5c5a55;margin:3px 0}}
code{{font-family:monospace;font-size:12px;background:#f2f0ec;border-radius:4px;padding:1px 6px}}
.acct{{display:inline-block;font-family:monospace;font-size:10.5px;padding:0 6px;border-radius:9px;margin-left:6px;background:#eaf2f9;color:#20507a}}
</style></head><body><header><div class="wrap">
<h1>Claude session atlas</h1><div class="sub">What every conversation has been building — last {days} days,
both accounts, grouped by project, <b>most recently active repo first</b>. The newest sessions in each
repo carry a GLM-written "where we left off" gist from the transcript tail. Regenerated daily 07:30 CT
(and on demand: <code>claude-session-atlas --publish</code>). Resume any session by pasting its command
in a terminal. Ladder view: <a href="{LADDER_URL}">session ladder</a>.
Updated {time.strftime('%Y-%m-%d %H:%M %Z')}.</div></div></header><div class="wrap">"""]
    live = live_status()
    for repo, rs in ordered:
        ago = _ago(time.time() - rs[0]["mtime"])
        parts.append(f'<h2><span class="n">{len(rs)}·</span> {e(repo)}'
                     f'<span class="ago">last active {ago}</span>{_heat(rs)}</h2>')
        for r in rs:
            when = time.strftime("%a %m-%d %H:%M", time.localtime(r["mtime"]))
            # unnamed sessions wear their first prompt as the title — an
            # empty "(unnamed)" marker tells the operator nothing
            if r["name"]:
                nm = f'<span class="nm">{e(r["name"])}</span>'
                topic = r.get("gist") or r["summary"] or r["first"]
            else:
                nm = ('<span class="nm" style="font-weight:500">'
                      f'{e((r["first"] or r["summary"] or "(empty session)")[:110])}</span>')
                topic = r.get("gist") or r["summary"] or ""
            badge = '<span class="live">● running</span>' if r["sid"] in live else ""
            parts.append(
                f'<div class="s"><span class="when">{when}</span> {nm}'
                f'<span class="acct">{r["acct"]}</span>{badge}'
                f'<div class="topic">{e(topic)}</div>'
                f'<code>{e(r["launcher"])} --resume {r["sid"]}</code>'
                f' <code style="opacity:.6">cd {e(r["cwd"])}</code></div>')
    parts.append("</div></body></html>")
    return "".join(parts)


