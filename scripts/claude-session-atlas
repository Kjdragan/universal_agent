def render_ladder(rows, days):
    """Design B: a vertical recency ladder. Today in full cards, this week in
    medium cards, this month as compact rows, older weeks collapsed to single
    groups — screen density falls off with age, no sideways scrolling."""
    e = html.escape
    counts, ranked, color = _project_colors(rows)
    keys, buckets = _day_buckets(rows, days)
    ov = _overview(keys, buckets)
    lg = _legend(counts, ranked, color)
    live = live_status()
    nk = len(keys)

    def wdlbl(k):
        return "%s %s" % (time.strftime("%a", time.strptime(k, "%Y-%m-%d")), k[5:])

    today_html, week, month = "", [], []
    for j in range(nk - 1, -1, -1):
        k, age, rs = keys[j], nk - 1 - j, buckets[keys[j]]
        if age > 30 or not rs:
            continue
        rs = list(reversed(rs))  # newest first within a group
        if age == 0:
            # today fans out into one column per repo, most recently
            # active repo first, that repo's sessions stacked beneath it
            groups = {}
            for x in rs:
                groups.setdefault(x["repo"], []).append(x)
            order = sorted(groups, key=lambda g: -groups[g][0]["mtime"])
            rcols = []
            for g in order:
                gs = groups[g]
                pills = "".join(_pill(x, color, "%H:%M", live) for x in gs)
                rcols.append('<div class="rcol"><div class="rh"><i style="background:%s">'
                             '</i>%s<span>%d</span></div>%s</div>'
                             % (color.get(g, TL_OTHER), e(g), len(gs), pills))
            today_html = ('<div class="day t0" data-d="%s" data-n="999">'
                          '<div class="dh">%s<span>%d</span></div>'
                          '<div class="gr cols">%s</div></div>'
                          % (k, wdlbl(k), len(rs), "".join(rcols)))
        elif age <= 7:
            week.append(_col(color, " t1", k, "", wdlbl(k), rs, 10, "%H:%M", live))
        else:
            month.append(_col(color, " t2 slim", k, "", wdlbl(k), rs, 5, "%H:%M", live))

    older, j = [], 0
    while j < nk and (nk - 1 - j) > 30:
        wk_keys = []
        while j < nk and (nk - 1 - j) > 30 and len(wk_keys) < 7:
            wk_keys.append(keys[j])
            j += 1
        rs = [r for kk in wk_keys for r in buckets[kk]]
        if rs:
            older.append(_col(color, " t3 slim", wk_keys[0], ' data-e="%s"' % wk_keys[-1],
                              "wk of %s" % wk_keys[0][5:], list(reversed(rs)), 5,
                              "%m-%d %H:%M", live))
    older.reverse()

    secs = []
    if today_html:
        secs.append('<section><h2>Today<span class="n">%d sessions</span></h2>%s</section>'
                    % (len(buckets[keys[-1]]), today_html))
    for title, chunk in (("This week", week), ("This month", month), ("Older", older)):
        if chunk:
            secs.append('<section><h2>%s</h2>%s</section>' % (title, "".join(chunk)))

    stamp = time.strftime("%Y-%m-%d %H:%M %Z")
    return ("""<!doctype html><html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Claude session ladder</title>""" + TL_CSS + LD_EXTRA + """</head><body>
<header><div class="wrap"><h1>Claude session ladder</h1>
<div class="sub">%d sessions · last %d days · both accounts · newest first, density falls with age:
Today in full cards, this week medium, this month compact, older weeks collapsed.
Click a card to expand its gist and resume command. Search covers titles, first prompts,
gists — and for recent sessions, words from the transcript tail. The strip jumps to any day.
List view: <a href="%s">session atlas</a>.
Updated %s.</div></div></header>
<div class="wrap">
<div class="ctl"><input id="q" type="search" placeholder="search %d sessions…">
<span id="cnt">%d of %d</span>
<button id="rf" data-u="%s" title="regenerate now from the desktop">↻ refresh</button>%s</div>
<div class="ov">%s</div>
%s
</div>""" % (len(rows), days, ATLAS_URL, stamp, len(rows), len(rows),
             len(rows), REFRESH_URL, lg, ov, "".join(secs))
            + LD_JS + "</body></html>")


def find(rows, query, limit=8):
    """Token-cheap lookup for in-session use: compact matches, resume-ready.
    A skill should call THIS, never Read the atlas HTML into context."""
    terms = [w for w in query.lower().split() if w]
    scored = []
    for r in rows:
        hay = " ".join([r["repo"], r["name"] or "", r["first"], r["summary"],
                        r.get("gist") or ""]).lower()
        score = sum(hay.count(w) for w in terms)
        if score:
            scored.append((score, r))
    scored.sort(key=lambda s: (-s[0], -s[1]["mtime"]))
    if not scored:
        print(f"no sessions match: {query}")
        return
    for score, r in scored[:limit]:
        when = time.strftime("%m-%d %H:%M", time.localtime(r["mtime"]))
        topic = (r["name"] or r["summary"] or r["first"])[:110]
        print(f"{when}  [{r['repo']}]  {topic}")
        print(f"        cd {r['cwd']} && {r['launcher']} --resume {r['sid']}")


def refresh_http():
    """Socket-activated (Accept=yes) one-shot HTTP handler: stdin/stdout ARE
    the connection. GET / regenerates + republishes (lock guards double-
    clicks); GET /launch?sid=<uuid> opens that session in a desktop terminal
    with the right launcher for its account. Only a sid is accepted from the
    request — cwd and launcher are resolved server-side from the transcript."""
    import fcntl
    from urllib.parse import urlparse, parse_qs
    try:
        req = sys.stdin.buffer.readline().decode("latin1", "replace")
    except Exception:
        req = ""
    parts = req.split()
    u = urlparse(parts[1] if len(parts) > 1 else "/")

    def respond(status, body):
        sys.stdout.buffer.write(
            b"HTTP/1.1 %s\r\nAccess-Control-Allow-Origin: *\r\n"
            b"Content-Type: text/plain\r\nContent-Length: %d\r\n"
            b"Connection: close\r\n\r\n%s" % (status, len(body), body))
        sys.stdout.buffer.flush()

    if u.path == "/launch":
        sid = (parse_qs(u.query).get("sid") or [""])[0]
        if not re.fullmatch(r"[0-9a-fA-F-]{36}", sid):
            respond(b"400 Bad Request", b"bad sid")
            return 0
        hit = None
        for _label, launcher, root in HOMES:
            g = glob.glob(os.path.join(root, "*", sid + ".jsonl"))
            if g:
                hit = (launcher, g[0])
                break
        if not hit:
            respond(b"404 Not Found", b"unknown session")
            return 0
        launcher, tpath = hit
        cwd = scan(tpath)[0]
        if not cwd or not os.path.isdir(cwd):
            cwd = os.path.expanduser("~")
        env = dict(os.environ)
        env.setdefault("DISPLAY", ":0")
        env.setdefault("DBUS_SESSION_BUS_ADDRESS",
                       "unix:path=/run/user/%d/bus" % os.getuid())
        subprocess.Popen(
            ["gnome-terminal", "--working-directory", cwd, "--", "bash", "-ic",
             "%s --resume %s; exec bash -i" % (launcher, sid)],
            env=env, start_new_session=True,
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        respond(b"200 OK", b"launched on the desktop")
        return 0

    lock = open("/tmp/claude-session-atlas.refresh.lock", "w")
    try:
        fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
        status, body = b"202 Accepted", b"refresh started; page rebuilds in ~1-2 min"
    except OSError:
        status, body = b"429 Too Many Requests", b"already refreshing"
    respond(status, body)
    if status[:3] != b"202":
        return 0
    try:  # release the browser before the slow part
        os.close(0)
        os.close(1)
    except Exception:
        pass
    log = open("/tmp/claude-session-atlas.refresh.log", "ab")
    return subprocess.run(
        [sys.executable, os.path.abspath(__file__), "--publish"],
        stdin=subprocess.DEVNULL, stdout=log, stderr=log).returncode


def main():
    a = sys.argv[1:]
    if "--refresh-http" in a:
        return refresh_http()
    days = int(a[a.index("--days") + 1]) if "--days" in a else 45
    cap = int(a[a.index("--max") + 1]) if "--max" in a else 140
    if "--find" in a:
        rows = collect(max(days, 90), 400)
        return find(rows, a[a.index("--find") + 1]) or 0
    # one scan feeds every page: the timeline/ladder carry EVERY session in
    # the window, the atlas stays the curated newest-N list with fresh gists
    tl_rows = collect(days, TL_MAX)
    rows = tl_rows[:cap]
    _ensure_zai_key()
    add_gists(tl_rows)
    build_deep_index(tl_rows)
    open(OUT, "w").write(render(rows, days))
    open(OUT2, "w").write(REDIRECT)  # retired timeline slug → ladder
    open(OUT3, "w").write(render_ladder(tl_rows, days))
    print(f"atlas: {len(rows)} sessions → {OUT} + ladder: {len(tl_rows)} → {OUT3}")
    if "--publish" in a:
        env = dict(os.environ, UA_SCRATCH_ARCHIVE_ENABLED="0")  # living pages — no per-day archive churn
        rc = 0
        for path, slug in ((OUT, "session-atlas"), (OUT2, "session-timeline"),
                           (OUT3, "session-ladder")):
            r = subprocess.run([PUBLISH, path, slug], env=env,
                               capture_output=True, text=True)
            print(r.stdout.strip() or r.stderr.strip()[-300:])
            rc = rc or r.returncode
        return rc
    return 0


if __name__ == "__main__":
    sys.exit(main())
